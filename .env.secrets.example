# ============================================================
# rwayve — SECRETS TEMPLATE
# ------------------------------------------------------------
# Copy this file to .env.secrets and fill in real values:
#
#     cp .env.secrets.example .env.secrets
#
# .env.secrets is gitignored. It is the ONLY file a new user
# must populate with credentials — everything secret lives here.
# Non-secret config (ports, URLs) is in backend/.env* and needs
# no editing for a default local run.
# ============================================================

# ---- Postgres ----
# The backend derives DATABASE_URL from these parts — do not add a DATABASE_URL
# line here. Change the password in one place and everything follows.
POSTGRES_DB=wayve_dev
POSTGRES_USER=wayve_user
POSTGRES_PASSWORD=wayve_password
POSTGRES_PORT=5432

# ---- Auth / encryption ----
# Dev defaults below are usable as-is for local runs. For anything shared or
# production, regenerate:  openssl rand -hex 64 (JWT)  |  openssl rand -hex 32 (AES)
JWT_SECRET=change-me-generate-with-openssl-rand-hex-64
AES_KEY=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f
AES_HKDF_SALT=change-me-generate-with-openssl-rand-hex-32

# ---- Google / Gmail OAuth (Google Cloud Console OAuth client) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Outlook / Microsoft OAuth (Azure app registration) ----
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=

# ---- Zoom (server-to-server OAuth) ----
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# ---- Gemini (AI) ----
GEMINI_API_KEY=

# ---- SMTP (outbound email credentials) ----
SMTP_USER=dev@example.local
SMTP_PASS=dev

# ---- Stripe (billing) — optional ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
