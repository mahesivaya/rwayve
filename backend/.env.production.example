ENV=production
RWAYVE_ENV=production
RWAYVE_ROLE=api
PORT=8080
FRONTEND_URL=https://app.example.com
BACKEND_URL=https://app.example.com
AUTH_COOKIE_SECURE=true

DATABASE_URL=postgres://wayve:change-me-long-random-password@postgres_db:5432/wayve
DATABASE_MAX_CONNECTIONS=20
REDIS_URL=redis://redis:6379

JWT_SECRET=change-me-generate-with-openssl-rand-hex-64
AES_KEY=change-me-generate-with-openssl-rand-hex-32
AES_HKDF_SALT=change-me-generate-with-openssl-rand-hex-32

GOOGLE_CLIENT_SECRET_PATH=/app/client_secret.json
GOOGLE_OAUTH_REDIRECT_URI=https://app.example.com/oauth/callback

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=change-me
SMTP_FROM=no-reply@example.com

ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
GEMINI_API_KEY=
RUST_LOG=info
