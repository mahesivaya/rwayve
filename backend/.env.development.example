# ─────────────────────────────────────────────────────────────────────────
# Backend NON-SECRET config template (development).
# Copy to backend/.env.development — no secrets here, so it usually needs
# no edits for a default local run.
#
# Secrets (DB password, JWT, AES, OAuth, SMTP creds, API keys) are NOT here —
# they live in /.env.secrets (copy from /.env.secrets.example).
# ─────────────────────────────────────────────────────────────────────────
ENV=development
RWAYVE_ENV=development
RWAYVE_ROLE=api
PORT=8080
FRONTEND_URL=http://localhost
BACKEND_URL=http://localhost:8080
AUTH_COOKIE_SECURE=false

DATABASE_MAX_CONNECTIONS=10
REDIS_URL=redis://localhost:6379

GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/oauth/callback

OUTLOOK_REDIRECT_URI=http://localhost:8080/oauth/outlook/callback
MICROSOFT_AUTHORITY=https://login.microsoftonline.com/consumers

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=dev@example.local

RUST_LOG=debug
