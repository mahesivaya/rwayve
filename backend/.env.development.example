ENV=development
RWAYVE_ENV=development
RWAYVE_ROLE=api
PORT=8080
FRONTEND_URL=http://localhost
BACKEND_URL=http://localhost:8080
AUTH_COOKIE_SECURE=false

DATABASE_URL=postgres://wayve_user:wayve_password@localhost:5432/wayve_dev
DATABASE_MAX_CONNECTIONS=10
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-generate-with-openssl-rand-hex-64
AES_KEY=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f
AES_HKDF_SALT=change-me-generate-with-openssl-rand-hex-32

GOOGLE_CLIENT_SECRET_PATH=../client_secret.json
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/oauth/callback

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=dev@example.local
SMTP_PASS=dev
SMTP_FROM=dev@example.local

ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
GEMINI_API_KEY=
RUST_LOG=debug
