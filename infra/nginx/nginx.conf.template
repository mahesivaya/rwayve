# Processed by the nginx image entrypoint (envsubst) at container start:
#   /etc/nginx/templates/nginx.conf.template  ->  /etc/nginx/nginx.conf
# Only CSP_* environment variables are substituted (NGINX_ENVSUBST_FILTER),
# so nginx runtime vars ($host, $remote_addr, $http_upgrade) are left intact.
events {}

http {
    access_log off;
    error_log /var/log/nginx/error.log warn;

    server {
        listen 80;

        add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' ${CSP_CONNECT_SRC} https: ws: wss:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'" always;

        # ✅ API
        location /api/ {
            # rewrite ^/api/(.*)$ /api/$1 break;
            proxy_pass http://backend:8080;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }

        # ✅ Gmail login
        location /gmail/ {
            proxy_pass http://backend:8080/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_redirect off;
        }

        # ✅ OAuth callback
        location /oauth/ {
            proxy_pass http://backend:8080/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_redirect off;
        }

        # ✅ WebSocket
        location /ws/ {
            proxy_pass http://backend:8080/ws/;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
        }

        # ✅ Frontend (ONLY ONE BLOCK)
        location / {
            proxy_pass http://frontend:5173/;
            proxy_set_header Host $host;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
        }
    }
}
