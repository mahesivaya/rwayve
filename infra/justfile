# =========================
# 🔧 BASIC
# =========================

run:
    cargo run

build:
    cargo build

release:
    cargo build --release

clean:
    cargo clean

# =========================
# 🧪 DEV
# =========================

dev:
    cargo watch -x run

fmt:
    cargo fmt

lint:
    cargo clippy -- -D warnings

# =========================
# 🐳 DOCKER
# =========================

compose-dev := "docker compose -f docker-compose.dev.yml --env-file .env.development"
compose-prod := "docker compose -f docker-compose.prod.yml --env-file .env.production"

dev-up:
    {{compose-dev}} up --build

dev-up-detached:
    {{compose-dev}} up -d --build

dev-up-workers:
    {{compose-dev}} --profile workers up --build

dev-down:
    {{compose-dev}} down

dev-logs:
    {{compose-dev}} logs -f

prod-up:
    {{compose-prod}} up -d --build

prod-down:
    {{compose-prod}} down

prod-logs:
    {{compose-prod}} logs -f

docker-build:
    {{compose-dev}} build

docker-up:
    {{compose-dev}} up

docker-up-detached:
    {{compose-dev}} up -d

docker-down:
    {{compose-dev}} down

docker-logs:
    {{compose-dev}} logs -f

docker-restart:
    {{compose-dev}} down
    {{compose-dev}} up --build

# =========================
# 🗄️ DATABASE
# =========================

db-up:
    {{compose-dev}} up postgres_db

db-reset:
    {{compose-dev}} down -v
    {{compose-dev}} up -d postgres_db

db-shell:
    docker exec -it rwayve_postgres_dev psql -U wayve_user -d wayve_dev

# =========================
# 🔐 SQLx
# =========================

sqlx-prepare:
    DATABASE_URL=postgres://wayve_user:wayve_password@localhost:5432/wayve_dev cargo sqlx prepare

sqlx-migrate:
    sqlx migrate run

# =========================
# 📧 BACKEND + FRONTEND
# =========================

start-all:
    {{compose-dev}} up --build

restart-backend:
    {{compose-dev}} restart backend

restart-nginx:
    {{compose-dev}} restart nginx

# =========================
# 🔥 GMAIL SYNC DEBUG
# =========================

logs-backend:
    docker logs -f rwayve_backend_dev

# =========================
# ⚡ SHORTCUTS
# =========================

r: run
d: dev
u: docker-up
ud: docker-up-detached
dd: docker-down

